<%- include("partials/head.ejs") %>
<%- include("partials/header.ejs") %>
<h2>Edit Job</h2>
<form method="POST" action="/jobs/edit/<%= job._id %>">
  <input type="hidden" name="_csrf" value="<%= _csrf %>">
  <div class="mb-3">
    <label for="company" class="form-label">Company</label>
    <input type="text" class="form-control" id="company" name="company" value="<%= job.company %>" required maxlength="50">
  </div>
  <div class="mb-3">
    <label for="position" class="form-label">Position</label>
    <input type="text" class="form-control" id="position" name="position" value="<%= job.position %>" required maxlength="100">
  </div>
  <div class="mb-3">
    <label for="status" class="form-label">Status</label>
    <select class="form-select" id="status" name="status">
      <option value="pending" <%= job.status === 'pending' ? 'selected' : '' %>>Pending</option>
      <option value="interview" <%= job.status === 'interview' ? 'selected' : '' %>>Interview</option>
      <option value="declined" <%= job.status === 'declined' ? 'selected' : '' %>>Declined</option>
    </select>
  </div>
  <button type="submit" class="btn btn-primary">Save Changes</button>
  <a href="/jobs" class="btn btn-secondary">Cancel</a>
</form>
<%- include("partials/footer.ejs") %>
