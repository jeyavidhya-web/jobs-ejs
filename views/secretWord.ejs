<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.2/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous" />
  <title>Secret Word</title>
</head>
<body
  
  class="container py-5">
  <!-- ✅ Include header partials -->
  <%- include("partials/head.ejs") %>
  <%- include("partials/header.ejs") %>
  <h1 class="mb-4">Secret Word</h1>
 <!-- ✅ Display the current secret word -->
  <p class="lead">The secret word is: <strong><%= secretWord %></strong></p>
  <p>Would you like to change it?</p>
  
  
   <!-- ✅ Form to change secret word -->
  <form method="POST"action="/secretWord" class="mt-4">
    <div class="mb-3">
<input type="hidden" name="_csrf" value="<%= _csrf %>">
    <label for="secretWord" class="form-label">Change the Secret Word:</label>
      <input type="text" name="secretWord" id="secretWord" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Submit</button>
  </form>
   <!-- ✅ Include footer -->
  <%- include("partials/footer.ejs") %>

</body>
</html>



  