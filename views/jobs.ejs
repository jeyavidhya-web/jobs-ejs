<%- include("partials/head.ejs") %>
<%- include("partials/header.ejs") %>
<h2>Jobs List</h2>
<a href="/jobs/add" class="btn btn-primary mb-3">Add Job</a>
<table class="table table-bordered">
  <thead>
    <tr>
      <th>Company</th>
      <th>Position</th>
      <th>Status</th>
      <th>Created</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% jobs.forEach(function(job) { %>
      <tr>
        <td><%= job.company %></td>
        <td><%= job.position %></td>
        <td><%= job.status %></td>
        <td><%= job.createdAt.toLocaleString() %></td>
        <td>
          <a href="/jobs/edit/<%= job._id %>" class="btn btn-sm btn-warning">Edit</a>
          <a href="/jobs/delete/<%= job._id %>" class="btn btn-sm btn-danger">Delete</a>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>
<%- include("partials/footer.ejs") %>
